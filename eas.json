{
  "cli": {
    "version": ">= 13.4.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": {
        "APP_ENV": "development"
      },
      "ios": {
        "simulator": false
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "autoIncrement": true,
      "env": {
        "APP_ENV": "preview",
        "EXPO_PUBLIC_API_URL": "https://sober-ai-api.onrender.com"
      },
      "ios": {
        "simulator": false
      }
    },
    "preview_store": {
      "distribution": "store",
      "channel": "preview",
      "autoIncrement": true,
      "env": {
        "APP_ENV": "preview",
        "EXPO_PUBLIC_API_URL": "https://sober-ai-api.onrender.com"
      }
    },
    "production": {
      "distribution": "store",
      "channel": "production",
      "autoIncrement": true,
      "env": {
        "APP_ENV": "production",
        "EXPO_PUBLIC_API_URL": "https://sober-ai-api.onrender.com"
      }
    }
  },
  "submit": {
    "preview": {},
    "preview_store": {},
    "production": {}
  }
}
