{
  "name": "@recovery/api",
  "version": "0.1.0",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "db:migrate": "tsx src/scripts/migrate.ts",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@recovery/policy-rbac": "workspace:*",
    "@recovery/shared-types": "workspace:*",
    "@recovery/shared-utils": "workspace:*",
    "fastify": "^5.2.1",
    "pg": "^8.18.0",
    "zod": "^3.24.1"
  }
}
