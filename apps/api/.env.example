API_HOST=0.0.0.0
API_PORT=3001
DATABASE_URL=postgres://postgres:postgres@localhost:5432/recovery_app
ENABLE_DEV_AUTH=true
LOG_LEVEL=info

# Meeting Guide ingest
MEETING_GUIDE_DEFAULT_TENANT_ID=tenant-a
MEETING_GUIDE_AUTO_INGEST=true
MEETING_GUIDE_REFRESH_INTERVAL_MS=43200000
MEETING_IMPORT_RADIUS_MILES=20

# Dev starter feed (built-in Billings sample with coordinates)
MEETING_GUIDE_FEEDS_JSON=[{"name":"Billings Test Feed","url":"builtin://billings-test","tenantId":"tenant-a"}]
