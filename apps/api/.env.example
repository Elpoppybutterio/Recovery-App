API_HOST=0.0.0.0
API_PORT=3001
DATABASE_URL=postgres://postgres:postgres@localhost:5432/recovery_app
ENABLE_DEV_AUTH=true
LOG_LEVEL=info

# Meeting Guide ingest
MEETING_GUIDE_DEFAULT_TENANT_ID=tenant-a
MEETING_GUIDE_AUTO_INGEST=true
MEETING_GUIDE_GEOCODE_MISSING=true
MEETING_GUIDE_GEOCODE_USER_AGENT=Recovery-Accountability/0.1 (+https://sober-ai.app)
MEETING_GUIDE_GITHUB_TOKEN=
MEETING_GUIDE_REFRESH_INTERVAL_MS=43200000
MEETING_IMPORT_RADIUS_MILES=20

# Dev starter feeds (real Meeting Guide city pages)
MEETING_GUIDE_FEEDS_JSON=[{"name":"AA Montana - Billings","url":"https://www.aa-montana.org/index.php?city=Billings","tenantId":"tenant-a"},{"name":"AA Montana - Laurel","url":"https://www.aa-montana.org/index.php?city=Laurel","tenantId":"tenant-a"},{"name":"NA Montana - Region","url":"https://namontana.org/wp-json/tsml/meetings","tenantId":"tenant-a"}]

# Example GitHub feed URL (Contents API)
# MEETING_GUIDE_FEEDS_JSON=[{"name":"GitHub Meetings","url":"https://api.github.com/repos/<owner>/<repo>/contents/<path>/meetings.json?ref=main","tenantId":"tenant-a"}]
