API_HOST=0.0.0.0
API_PORT=3001
DATABASE_URL=postgres://postgres:postgres@localhost:5432/recovery_app
ENABLE_DEV_AUTH=true
LOG_LEVEL=info

# Meeting Guide ingest
MEETING_GUIDE_DEFAULT_TENANT_ID=tenant-a
MEETING_GUIDE_AUTO_INGEST=true
MEETING_GUIDE_GEOCODE_MISSING=true
MEETING_GUIDE_GEOCODE_VERIFY_EXISTING=true
MEETING_GUIDE_GOOGLE_VERIFY=true
# Set in Render dashboard as an env var (do not commit secrets).
# This key is separate from MEETING_GUIDE_FEEDS_JSON.
GOOGLE_MAPS_API_KEY=
MEETING_GUIDE_GEOCODE_USER_AGENT=Recovery-Accountability/0.1 (+https://sober-ai.app)
MEETING_GUIDE_GITHUB_TOKEN=
MEETING_GUIDE_REFRESH_INTERVAL_MS=43200000
MEETING_IMPORT_RADIUS_MILES=20

# Location-aware feed registry.
# The API now uses the caller's lat/lng to warm and query the closest configured region.
# coverageCenterLat/coverageCenterLng/coverageRadiusMiles are optional but recommended.
# coverageStates / coverageCountryCodes allow coarse routing for statewide or nationwide feeds.
# Replace these examples with the actual regional Meeting Guide or TSML feeds you want to support.
MEETING_GUIDE_FEEDS_JSON=[{"name":"AA Montana - Billings","url":"https://www.aa-montana.org/index.php?city=Billings","tenantId":"tenant-a","coverageCenterLat":45.7833,"coverageCenterLng":-108.5007,"coverageRadiusMiles":80,"coverageStates":["MT"],"coverageCountryCodes":["US"]},{"name":"AA Montana - Laurel","url":"https://www.aa-montana.org/index.php?city=Laurel","tenantId":"tenant-a","coverageCenterLat":45.6691,"coverageCenterLng":-108.7707,"coverageRadiusMiles":45,"coverageStates":["MT"],"coverageCountryCodes":["US"]},{"name":"NA Montana - Region","url":"https://namontana.org/wp-json/tsml/meetings","tenantId":"tenant-a","coverageCenterLat":46.8797,"coverageCenterLng":-110.3626,"coverageRadiusMiles":350,"coverageStates":["MT"],"coverageCountryCodes":["US"]}]

# Example GitHub feed URL (Contents API)
# MEETING_GUIDE_FEEDS_JSON=[{"name":"GitHub Meetings","url":"https://api.github.com/repos/<owner>/<repo>/contents/<path>/meetings.json?ref=main","tenantId":"tenant-a"}]
